---
import HomeLayout from '@/layouts/HomeLayout.astro'
import siteConfig from '@/site-config'
import MeteorsAnimation from '@/components/MeteorsAnimation.astro'
import StarsAnimation from '@/components/StarsAnimation.astro'
import StarsBackground from '@/components/StarsBackground.astro'
import ParticlesBackground from '@/components/ParticlesBackground.astro'
---

<HomeLayout description={siteConfig.description}>
  <!-- Light Mode: Particles -->
  <ParticlesBackground />

  <!-- Dark Theme: Stars and meteors -->
  <StarsBackground />
  <div id="galaxy" class="fixed inset-0">
    <div class="hidden dark:block">
      <StarsAnimation />
      <MeteorsAnimation />
    </div>
  </div>

  <!-- HERO -->
  <section class="relative h-screen w-full">
    <div class="absolute h-full w-full flex items-center justify-center">
      <div class="relative w-full h-full flex items-center justify-center">
        <div class="p-5 text-center">
          <p class="text-lg md:text-xl lg:text-2xl font-semibold opacity-75">
            Hello, I am ...
          </p>
          <p
            class="text-2xl md:text-3xl lg:text-4xl font-bold uppercase text-black dark:text-white"
          >
            Jesus Pinar
          </p>
          <p class="text-sm md:text-base lg:text-lg opacity-75">
            Software developer.
          </p>
          <div id="ctaButtons" class="flex flex-wrap gap-4 justify-center mt-5">
            <a
              href="/blog"
              class="py-2 px-4 truncate rounded text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 blend"
            >
              Read my blog
            </a>
            <a
              href="/projects"
              class="py-2 px-4 rounded truncate text-xs md:text-sm lg:text-base bg-black dark:bg-white text-white dark:text-black hover:opacity-75 blend"
            >
              View my work
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</HomeLayout>
